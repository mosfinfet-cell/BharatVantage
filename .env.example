# ── App ────────────────────────────────────────────────────
APP_NAME=BharatVantage
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Database (Railway PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/bharatvantage

# ── Redis (Railway Redis) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Cloudflare R2 ──────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=bharatvantage-uploads
R2_PUBLIC_URL=                          # optional: public CDN URL for bucket

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://bharat-vantage.vercel.app"]

# ── Limits ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=200
MAX_SESSION_SIZE_MB=500
