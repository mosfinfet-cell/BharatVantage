# Environment and Secrets
# .env contains DATABASE_URL, SECRET_KEY, R2 credentials - NEVER commit this
.env
.env.local
.env.*.local
.env.production
.env.staging

# .env.example is SAFE to commit - it has placeholder values only
# Do NOT add .env.example to this file

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environment
venv/
env/
ENV/
.venv/

# Distribution and packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing and coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# Alembic
# alembic/versions/ IS committed - it is the schema history
alembic/versions/*.py.bak

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# Local uploads and temp files
uploads/
tmp/
temp/
*.tmp

# Logs
*.log
logs/
